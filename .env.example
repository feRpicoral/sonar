# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Supabase ===
# Use the new publishable/secret keys (sb_publishable_xxx / sb_secret_xxx).
# Legacy anon/service_role JWTs work too; the SDK treats both as opaque bearer tokens.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Database (Supabase Postgres) ===
# DATABASE_URL is the pooled connection (port 6543). DIRECT_URL is the direct
# connection (port 5432) used by `prisma migrate` and `psql`.
DATABASE_URL=
DIRECT_URL=

# === Anthropic (Claude Sonnet 4.6 + Haiku 4.5) ===
ANTHROPIC_API_KEY=

# === Groq (Whisper Large v3) ===
GROQ_API_KEY=

# === Tavily (web search for research agent) ===
TAVILY_API_KEY=

# === Stripe (test mode) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO=

# === Resend ===
# A "Sending access" key is enough; full access is unnecessary.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# === Webhooks ===
# 32-byte key (base64 or hex) used to encrypt outbound webhook signing secrets
# at rest. Generate with: openssl rand -base64 32
WEBHOOK_ENCRYPTION_KEY=

# === Observability (optional, leave unset to disable) ===
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Not yet wired up (deferred features) ===
# - RESEND_WEBHOOK_SECRET: needed only when the /api/webhooks/resend delivery
#   status handler is implemented.
# - UPSTASH_REDIS_REST_URL / TOKEN: needed only when per-org rate limiting is
#   implemented on /api/runs/start.
# - INNGEST_EVENT_KEY / SIGNING_KEY: needed only if the agent runner is moved
#   from Next.js after() into Inngest functions (recommended if the 60s Vercel
#   Hobby timeout becomes an issue).
# - LANGSMITH_API_KEY / LANGSMITH_PROJECT: needed only when Anthropic SDK
#   calls are wrapped with LangSmith tracing and AgentRun.traceUrl is set.
